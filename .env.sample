# Jarvis local development environment
# Expose your API keys and local paths here. Do not commit real secrets.

# Groq API (optional for MVP; enable if you have a Groq account)
# GROQ_API_ENDPOINT=https://your-groq-endpoint.example.com/v1/predict
# GROQ_API_KEY=your-groq-api-key

# Local SQLite DB path (relative to repo root if not using an absolute path)
# JARVIS_SQLITE_PATH=server/jarvis.db

# Optional: override port (not needed for Render)
# PORT=8000
